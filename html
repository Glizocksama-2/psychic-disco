 <!DOCTYPE html>
  <html lang="en">
  <head>
      <meta charset="UTF-8">                                                                                                  <meta name="viewport" content="width=device-width, initial-scale=1.0">
      <title>Wren Command | Mission Control</title>                                                                           <script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
      <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
      <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
      <script src="https://cdn.tailwindcss.com"></script>
      <script src="https://unpkg.com/lucide-react"></script>
      <style>
          body {
              background-color: #0a0a0f;
              color: #e2e8f0;
              font-family: 'Inter', system-ui, -apple-system, sans-serif;
              overflow: hidden;
          }
          .custom-scrollbar::-webkit-scrollbar {
              width: 4px;
          }
          .custom-scrollbar::-webkit-scrollbar-track {
              background: #0a0a0f;
          }
          .custom-scrollbar::-webkit-scrollbar-thumb {
              background: #1f2937;
              border-radius: 10px;
          }
          .glass-panel {
              background: #111827;
              border: 1px solid #1f2937;
          }
          .accent-glow {
              box-shadow: 0 0 15px rgba(59, 130, 246, 0.2);
          }
      </style>
  </head>
  <body>
      <div id="root"></div>

      <script type="text/babel">
          const { useState, useEffect, useMemo } = React;

          // --- INITIAL SEED DATA ---
          const INITIAL_PROJECTS = [
              { id: 'yt-auto', name: 'yt-auto', description: 'YouTube Shorts automation pipeline', status: 'Active',
  progress: 60, tags: ['Python', 'n8n', 'Docker'], lastUpdated: '2026-04-09' },
              { id: 'liferpg', name: 'LifeRPG', description: 'Habit RPG PWA', status: 'Active', progress: 75, tags:
  ['React', 'Groq', 'Netlify'], lastUpdated: '2026-04-09' },
              { id: 'sakawera', name: 'Saka Wera', description: 'Kenyan job search automation', status: 'Active',
  progress: 85, tags: ['n8n', 'PostgreSQL', 'Docker'], lastUpdated: '2026-04-09' },
              { id: 'megatron', name: 'Megatron', description: 'AI Chief of Staff, Telegram bot', status: 'Active',
  progress: 90, tags: ['n8n', 'Telegram API', 'Claude'], lastUpdated: '2026-04-09' },
              { id: 'wrenos', name: 'Wren OS', description: 'Agent management dashboard', status: 'Paused', progress:
  40, tags: ['React', 'PocketBase'], lastUpdated: '2026-04-08' },
              { id: 'freelance', name: 'Freelance Pipeline', description: 'Fiverr lead tracker', status: 'Active',
  progress: 50, tags: ['React', 'AI Agents'], lastUpdated: '2026-04-09' },
          ];

          const INITIAL_LOGS = [
              { timestamp: '2026-04-10 21:00', project: 'Saka Wera', action: 'Briefing Generated', output: 'Trigger.dev
  evaluation suggested', status: '✅' },
              { timestamp: '2026-04-10 20:45', project: 'yt-auto', action: 'Pipeline Run', output: '3 shorts generated
  successfully', status: '✅' },
              { timestamp: '2026-04-10 19:30', project: 'LifeRPG', action: 'Deployment', output: 'Netlify function
  deployed', status: '✅' },
              { timestamp: '2026-04-10 15:00', project: 'Megatron', action: 'Telegram Sync', output: 'Webhook responded
  with 403', status: '❌' },
              { timestamp: '2026-04-09 23:00', project: 'Wren OS', action: 'Semauntic Search', output: 'Vector store
  indexed', status: '⚠️' },
          ];

          // --- UTILITIES ---
          const storage = {
              get: (key, fallback) => JSON.parse(localStorage.getItem(`wren_${key}`)) || fallback,
              set: (key, val) => localStorage.setItem(`wren_${key}`, JSON.stringify(val))
          };

          // --- COMPONENTS ---
          const Icon = ({ name, className = "w-4 h-4" }) => {
              const LucideIcon = lucide[name];
              return LucideIcon ? <LucideIcon className={className} /> : null;
          };

          const MetricsBar = ({ activeCount, completedToday, focusProject, onSettingsClick }) => (
              <div className="h-16 w-full glass-panel flex items-center justify-between px-6 z-50 sticky top-0">
                  <div className="flex items-center gap-6">
                      <div className="flex items-center gap-2">
                          <div className="w-3 h-3 rounded-full bg-blue-500 accent-glow animate-pulse"></div>
                          <span className="text-xs font-mono text-slate-400 uppercase tracking-widest">System
  Online</span>
                      </div>
                      <div className="h-4 w-px bg-slate-800"></div>
                      <div className="text-sm">
                          <span className="text-slate-500">Projects:</span> <span className="font-bold
  text-blue-400">{activeCount}</span>
                      </div>
                      <div className="text-sm">
                          <span className="text-slate-500">Tasks Done:</span> <span className="font-bold
  text-cyan-400">{completedToday}</span>
                      </div>
                  </div>
                  <div className="flex items-center gap-4">
                      <div className="text-xs text-right">
                          <div className="text-slate-500 uppercase text-[10px]">Current Focus</div>
                          <div className="font-bold text-white">{focusProject || 'None'}</div>
                      </div>
                      <button onClick={onSettingsClick} className="p-2 hover:bg-slate-800 rounded-lg transition-colors">
                          <Icon name="Settings" />
                      </button>
                  </div>
              </div>
          );

          const ProjectCard = ({ project, isActive, onClick }) => (
              <div
                  onClick={onClick}
                  className={`p-4 mb-3 cursor-pointer transition-all duration-200 rounded-lg border ${
                      isActive ? 'bg-blue-900/20 border-blue-500 shadow-lg shadow-blue-500/10' : 'glass-panel
  border-slate-800 hover:border-slate-700'
                  }`}
              >
                  <div className="flex justify-between items-start mb-2">
                      <h3 className="font-bold text-slate-100">{project.name}</h3>
                      <span className={`text-[10px] px-2 py-0.5 rounded-full font-medium ${
                          project.status === 'Active' ? 'bg-green-500/10 text-green-400' : 'bg-amber-500/10
  text-amber-400'
                      }`}>
                          {project.status}
                      </span>
                  </div>
                  <p className="text-xs text-slate-400 mb-3 line-clamp-1">{project.description}</p>
                  <div className="flex items-center gap-2 mb-1">
                      <div className="flex-1 h-1 bg-slate-800 rounded-full overflow-hidden">
                          <div className="h-full bg-blue-500 transition-all duration-500" style={{ width:
  `${project.progress}%` }}></div>
                      </div>
                      <span className="text-[10px] font-mono text-slate-500">{project.progress}%</span>
                  </div>
              </div>
          );

          const TaskList = ({ projectId, tasks, onToggle, onAdd }) => {
              const [newTask, setNewTask] = useState('');
              const projectTasks = tasks.filter(t => t.projectId === projectId);

              return (
                  <div className="mt-6">
                      <div className="flex justify-between items-center mb-4">
                          <h4 className="text-sm font-bold uppercase tracking-wider text-slate-400 flex items-center
  gap-2">
                              <Icon name="CheckSquare" className="w-4 h-4" /> Task Queue
                          </h4>
                          <span className="text-xs text-slate-500 font-mono">
                              {projectTasks.filter(t => t.status === 'done').length} / {projectTasks.length} Complete
                          </span>
                      </div>
                      <div className="space-y-2 mb-4">
                          {projectTasks.map(task => (
                              <div key={task.id} className="flex items-center gap-3 p-2 rounded-md hover:bg-slate-800/50
   group">
                                  <input
                                      type="checkbox"
                                      checked={task.status === 'done'}
                                      onChange={() => onToggle(task.id)}
                                      className="w-4 h-4 rounded border-slate-700 bg-slate-900 text-blue-500
  focus:ring-blue-500"
                                  />
                                  <span className={`text-sm flex-1 ${task.status === 'done' ? 'text-slate-500
  line-through' : 'text-slate-300'}`}>
                                      {task.title}
                                  </span>
                                  <span className={`text-[10px] px-2 py-0.5 rounded font-bold ${
                                      task.priority === 'High' ? 'text-red-400 bg-red-400/10' :
                                      task.priority === 'Med' ? 'text-amber-400 bg-amber-400/10' : 'text-green-400
  bg-green-400/10'
                                  }`}>
                                      {task.priority}
                                  </span>
                              </div>
                          ))}
                      </div>
                      <div className="flex gap-2">
                          <input
                              className="flex-1 bg-slate-900 border border-slate-800 rounded-md px-3 py-1.5 text-sm
  focus:outline-none focus:border-blue-500 text-slate-200"
                              placeholder="Add new mission objective..."
                              value={newTask}
                              onChange={(e) => setNewTask(e.target.value)}
                              onKeyDown={(e) => e.key === 'Enter' && (onAdd(newTask), setNewTask(''))}
                          />
                          <button
                              onClick={() => { onAdd(newTask); setNewTask(''); }}
                              className="bg-blue-600 hover:bg-blue-500 text-white px-3 py-1.5 rounded-md text-sm
  transition-colors"
                          >
                              Add
                          </button>
                      </div>
                  </div>
              );
          };

          const BriefingPanel = ({ project, apiKey, setApiKey }) => {
              const [loading, setLoading] = useState(false);
              const [briefing, setBriefing] = useState(null);

              const requestBriefing = async () => {
                  if (!apiKey) {
                      alert('Please configure Anthropic API Key in settings.');
                      return;
                  }
                  setLoading(true);
                  setBriefing(null);
                  try {
                      const response = await fetch('https://api.anthropic.com/v1/messages', {
                          method: 'POST',
                          headers: {
                              'Content-Type': 'application/json',
                              'x-api-key': apiKey,
                              'anthropic-version': '2023-06-01'
                          },
                          body: JSON.stringify({
                              model: 'claude-3-5-sonnet-20240620',
                              max_tokens: 1024,
                              system: 'You are Megatron, Brian\'s AI Chief of Staff. Generate a concise, direct project
  briefing. No fluff. Lead with status. End with one clear action. Format with emoji section headers and clear spacing
  for readability.',
                              messages: [{ role: 'user', content: `Generate a briefing for project: ${project.name}.
  Description: ${project.description}. Status: ${project.status}. Progress: ${project.progress}%.` }]
                          })
                      });
                      const data = await response.json();
                      setBriefing(data.content[0].text);
                  } catch (e) {
                      setBriefing('❌ Error fetching briefing. Check API key and network.');
                  } finally {
                      setLoading(false);
                  }
              };

              return (
                  <div className="mt-8 p-6 glass-panel rounded-xl border-blue-500/30 accent-glow">
                      <div className="flex justify-between items-center mb-6">
                          <h4 className="text-sm font-bold uppercase tracking-wider text-blue-400 flex items-center
  gap-2">
                              <Icon name="Zap" className="w-4 h-4" /> Intelligence Briefing
                          </h4>
                          <button
                              onClick={requestBriefing}
                              disabled={loading}
                              className="bg-blue-600 hover:bg-blue-500 disabled:bg-slate-700 text-white text-xs px-4
  py-2 rounded-lg transition-all flex items-center gap-2"
                          >
                              {loading ? <div className="w-3 h-3 border-2 border-white border-t-transparent rounded-full
   animate-spin"></div> : <Icon name="Terminal" className="w-3 h-3" />}
                              {loading ? 'Consulting Megatron...' : 'Brief Me'}
                          </button>
                      </div>
                      {briefing ? (
                          <div className="text-sm text-slate-300 whitespace-pre-wrap leading-relaxed font-mono
  bg-slate-900/50 p-4 rounded-lg border border-slate-800">
                              {briefing}
                          </div>
                      ) : (
                          <div className="text-center py-12 text-slate-500 italic text-sm">
                              {loading ? 'Accessing secure intelligence channels...' : 'No active briefing. Trigger
  Megatron for current status.'}
                          </div>
                      )}
                  </div>
              );
          };

          const CommandLog = ({ logs }) => (
              <div className="fixed right-0 top-16 w-80 h-[calc(100vh-64px)] glass-panel border-l border-slate-800 flex
  flex-col">
                  <div className="p-4 border-b border-slate-800 flex justify-between items-center">
                      <span className="text-xs font-bold uppercase tracking-widest text-slate-500 flex items-center
  gap-2">
                          <Icon name="Activity" className="w-3 h-3" /> Command Log
                      </span>
                      <span className="text-[10px] font-mono text-slate-600">LIVE</span>
                  </div>
                  <div className="flex-1 overflow-y-auto p-4 space-y-3 custom-scrollbar">
                      {logs.map((log, i) => (
                          <div key={i} className="text-[11px] font-mono border-l-2 border-slate-700 pl-3 py-1">
                              <div className="flex justify-between text-slate-500 mb-1">
                                  <span>{log.timestamp}</span>
                                  <span>{log.status}</span>
                              </div>
                              <div className="text-slate-300">
                                  <span className="text-blue-400 font-bold">[{log.project}]</span> {log.action}
                              </div>
                              <div className="text-slate-500 truncate">{log.output}</div>
                          </div>
                      ))}
                  </div>
              </div>
          );

          const SettingsModal = ({ isOpen, onClose, settings, setSettings }) => {
              if (!isOpen) return null;
              return (
                  <div className="fixed inset-0 z-[100] flex items-center justify-center bg-black/80 backdrop-blur-sm
  p-4">
                      <div className="w-full max-w-md glass-panel p-6 rounded-2xl border-slate-700">
                          <div className="flex justify-between items-center mb-6">
                              <h2 className="text-lg font-bold flex items-center gap-2">
                                  <Icon name="Settings" /> System Configuration
                              </h2>
                              <button onClick={onClose} className="text-slate-500 hover:text-white">
                                  <Icon name="X" />
                              </button>
                          </div>
                          <div className="space-y-4">
                              <div>
                                  <label className="block text-xs text-slate-500 uppercase mb-1">Anthropic API
  Key</label>
                                  <input
                                      type="password"
                                      className="w-full bg-slate-900 border border-slate-800 rounded-md px-3 py-2
  text-sm text-white focus:border-blue-500 outline-none"
                                      value={settings.apiKey}
                                      onChange={e => setSettings({...settings, apiKey: e.target.value})}
                                  />
                              </div>
                              <div>
                                  <label className="block text-xs text-slate-500 uppercase mb-1">Briefing Model</label>
                                  <select
                                      className="w-full bg-slate-900 border border-slate-800 rounded-md px-3 py-2
  text-sm text-white outline-none"
                                      value={settings.model}
                                      onChange={e => setSettings({...settings, model: e.target.value})}
                                  >
                                      <option value="claude-3-5-sonnet-20240620">Claude 3.5 Sonnet</option>
                                      <option value="claude-3-opus-20240229">Claude 3 Opus</option>
                                  </select>
                              </div>
                              <div>
                                  <label className="block text-xs text-slate-500 uppercase mb-1">Telegram Webhook
  URL</label>
                                  <input
                                      className="w-full bg-slate-900 border border-slate-800 rounded-md px-3 py-2
  text-sm text-white outline-none"
                                      value={settings.telegramWebhook}
                                      onChange={e => setSettings({...settings, telegramWebhook: e.target.value})}
                                  />
                              </div>
                          </div>
                          <div className="mt-8 flex gap-3">
                              <button
                                  onClick={onClose}
                                  className="flex-1 bg-blue-600 hover:bg-blue-500 text-white py-2 rounded-lg font-bold
  text-sm transition-colors"
                              >
                                  Save & Close
                              </button>
                          </div>
                      </div>
                  </div>
              );
          };

          const App = () => {
              const [projects, setProjects] = useState(() => storage.get('projects', INITIAL_PROJECTS));
              const [tasks, setTasks] = useState(() => storage.get('tasks', []));
              const [logs, setLogs] = useState(() => storage.get('logs', INITIAL_LOGS));
              const [settings, setSettings] = useState(() => storage.get('settings', { apiKey: '', model:
  'claude-3-5-sonnet-20240620', telegramWebhook: '', accentColor: '#3b82f6' }));
              const [selectedId, setSelectedId] = useState(projects[0]?.id);
              const [isSettingsOpen, setIsSettingsOpen] = useState(false);

              useEffect(() => {
                  storage.set('projects', projects);
                  storage.set('tasks', tasks);
                  storage.set('settings', settings);
                  storage.set('logs', logs);
              }, [projects, tasks, settings, logs]);

              const selectedProject = useMemo(() => projects.find(p => p.id === selectedId), [projects, selectedId]);
              const completedToday = tasks.filter(t => t.status === 'done').length;

              const toggleTask = (taskId) => {
                  setTasks(prev => prev.map(t => t.id === taskId ? { ...t, status: t.status === 'done' ? 'pending' :
  'done' } : t));
              };

              const addTask = (title) => {
                  if (!title) return;
                  const newTask = { id: Date.now(), projectId: selectedId, title, status: 'pending', priority: 'Med' };
                  setTasks(prev => [...prev, newTask]);
              };

              return (
                  <div className="h-screen flex flex-col">
                      <MetricsBar
                          activeCount={projects.filter(p => p.status === 'Active').length}
                          completedToday={completedToday}
                          focusProject={selectedProject?.name}
                          onSettingsClick={() => setIsSettingsOpen(true)}
                      />

                      <div className="flex flex-1 overflow-hidden">
                          {/* Project Sidebar */}
                          <div className="w-72 glass-panel border-r border-slate-800 overflow-y-auto p-4
  custom-scrollbar">
                              <div className="flex items-center justify-between mb-6 px-2">
                                  <h2 className="text-xs font-bold uppercase tracking-widest text-slate-500">Mission
  Queue</h2>
                                  <div className="w-2 h-2 rounded-full bg-blue-500 animate-pulse"></div>
                              </div>
                              {projects.map(p => (
                                  <ProjectCard
                                      key={p.id}
                                      project={p}
                                      isActive={selectedId === p.id}
                                      onClick={() => setSelectedId(p.id)}
                                  />
                              ))}
                          </div>

                          {/* Main Detail Area */}
                          <div className="flex-1 overflow-y-auto p-8 custom-scrollbar bg-[#0a0a0f]">
                              {selectedProject ? (
                                  <div className="max-w-4xl mx-auto">
                                      <div className="flex justify-between items-end mb-8">
                                          <div>
                                              <div className="flex items-center gap-3 mb-2">
                                                  <h1 className="text-4xl font-black text-white
  tracking-tight">{selectedProject.name}</h1>
                                                  <span className="px-3 py-1 rounded-full bg-blue-500/10 text-blue-400
  text-xs font-bold border border-blue-500/20">
                                                      {selectedProject.status}
                                                  </span>
                                              </div>
                                              <p className="text-slate-400 text-lg">{selectedProject.description}</p>
                                          </div>
                                          <div className="text-right">
                                              <div className="text-xs text-slate-500 uppercase mb-1">Last Sync</div>
                                              <div className="text-sm font-mono
  text-slate-300">{selectedProject.lastUpdated}</div>
                                          </div>
                                      </div>

                                      <div className="grid grid-cols-3 gap-4 mb-8">
                                          {selectedProject.tags.map(tag => (
                                              <div key={tag} className="p-3 glass-panel rounded-lg border-slate-800
  text-center">
                                                  <span className="text-xs text-slate-500 block uppercase
  mb-1">Stack</span>
                                                  <span className="text-sm font-bold text-slate-200">{tag}</span>
                                              </div>
                                          ))}
                                      </div>

                                      <div className="grid grid-cols-1 lg:grid-cols-2 gap-8">
                                          <TaskList
                                              projectId={selectedId}
                                              tasks={tasks}
                                              onToggle={toggleTask}
                                              onAdd={addTask}
                                          />
                                          <BriefingPanel
                                              project={selectedProject}
                                              apiKey={settings.apiKey}
                                              setApiKey={setSettings}
                                          />
                                      </div>
                                  </div>
                              ) : (
                                  <div className="h-full flex items-center justify-center text-slate-600 italic">
                                      Select a project from the queue to begin.
                                  </div>
                              )}
                          </div>
                      </div>

                      <CommandLog logs={logs} />
                      <SettingsModal
                          isOpen={isSettingsOpen}
                          onClose={() => setIsSettingsOpen(false)}
                          settings={settings}
                          setSettings={setSettings}
                      />
                  </div>
              );
          };

          const root = ReactDOM.createRoot(document.getElementById('root'));
          root.render(<App />);
      </script>
  </body>
  </html>
